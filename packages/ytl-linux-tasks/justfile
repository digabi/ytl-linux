# A group of tasks essential for every healthy YTL Linux installation.
[private]
maintenance: migrate-package-keys remove-virtualbox

# Installs public keys of package sources to supported location
migrate-package-keys:
    './scripts/2026-02-18_migrate-package-keys.py'

# Remove VirtualBox 7.1 and its requirements (autopurge)
remove-virtualbox:
    './scripts/2026-04-16_remove-virtualbox.sh'

archive-digabi2-database:
    #!/usr/bin/env bash
    set -euo pipefail

    timestamp=$(date '+%Y-%m-%d-%H%M%S')
    archive_path="{{ invocation_directory() }}/digabi2-dbdata-${timestamp}.tar.gz"
    mountpoint=$(docker inspect digabi2_dbdata | jq -r '.[0].Mountpoint')
    sudo tar cvzf "${archive_path}" "${mountpoint%/*}"
    echo "Digabi2 database archive created: ${archive_path}"
    open "{{ invocation_directory() }}"
