    configure_static_dns_records "$SERVER_NUMBER"
fi

write_file $PATH_SERVER_FRIENDLY_NAME_CONF "$SERVER_FRIENDLY_NAME"

enable_systemd_services
restart_systemd_resolved
restart_dnsmasq
restart_examnet_daemon

debug "Configuring Docker daemon"
ytl-linux-digabi2-docker-configure.sh "${IP_WAN}" "${SERVER_OWN_IP}"
