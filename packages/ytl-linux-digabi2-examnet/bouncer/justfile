# Lists all tasks in the order they appear in the justfile
[private]
default:
    @just --list --unsorted

# Format justfiles
[private]
format:
    @just --unstable --fmt

start: generate-dev-conf
    #!/usr/bin/env bash
    set -euo pipefail

    PATH_SERVER_FRIENDLY_NAME_CONF=devconf/server-friendly-name
    PATH_NAKSU2_DOMAIN=devconf/domain.txt
    PATH_EXAMNET_CONFIG=../conf
    PATH_SERVER_OWN_IP=devconf/server-own-ip
    PATH_NAKSU2_CERTS_DIR=devconf
    # This is intentionally [almost] identical to its equivalent in the examnet script
    CONFIG=$(cat <<EOF
    {
        "config": {
            "friendlyName": $(jq -Rc . "$PATH_SERVER_FRIENDLY_NAME_CONF"),
            "canonicalHostname": $(jq -Rc . "$PATH_NAKSU2_DOMAIN"),
            "ncsiHostnames": $(jq -Rc '.|split(",")|map(select(.!=""))' "$PATH_EXAMNET_CONFIG/ncsi-hostnames"),
            "searchDomain": "internal",
            "serverOwnIp": $(jq -Rc . "$PATH_SERVER_OWN_IP"),
            "ports": {"discovery": 26242, "bouncer": 80}
        },
        "secrets": $(jq -nc '{cert:$cert, key:$key}' \
            --arg cert "$PATH_NAKSU2_CERTS_DIR/cert.pem" \
            --arg key "$PATH_NAKSU2_CERTS_DIR/key.pem"
        )
    }
    EOF
    )
    deno run dev "$CONFIG"

test:
    deno run tests

generate-dev-conf friendly-name="pomppulinna" skip-cert-if-exists="true":
    #!/usr/bin/env bash
    set -euo pipefail

    rm -rf devconf
    mkdir -p devconf

    KTP_DOMAINS=()

    # Generate fake DNS records file that mimics that generated by ytl-linux-digabi2-examnet
    for i in $(seq 1 24); do
        KTP_DOMAINS+=(ktp$i.1000.koe.abitti.net)
        echo "host-record=ktp$i.1000.koe.abitti.net,192.168.$((i * 10)).1" >> devconf/ytl-linux-static-dns-records.conf
    done

    if [[ "{{ skip-cert-if-exists }}" == "false" || (! -f devconf/cert.pem && ! -f devconf/key.pem) ]]; then
        # Generate fake certificate that mimics the ones generated for schools
        mkcert -cert-file devconf/cert.pem -key-file devconf/key.pem ${KTP_DOMAINS[@]}
    fi

    echo '{{ friendly-name }}' > devconf/server-friendly-name
    echo 'ktp1.1000.koe.abitti.net' > devconf/domain.txt
    echo '192.168.10.1' > devconf/server-own-ip
