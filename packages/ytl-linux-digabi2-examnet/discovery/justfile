# Lists all tasks in the order they appear in the justfile
[private]
default:
    @just --list --unsorted

# Format justfiles
[private]
format:
    @just --unstable --fmt

start prod-mode="false" only-to-console="false": generate-dev-conf
    #!/usr/bin/env bash
    set -euo pipefail

    PATH_DNSMASQ_STATIC_DNS_CONF=devconf/ytl-linux-static-dns-records.conf
    PATH_DNSMASQ_KTP_ALIASES_CONF=devconf/ytl-linux-ktp-aliases.conf
    DISCOVERY_PORT=26464

    CONFIG=$(cat <<EOF
    {
        "config": {
            "isProd": {{ prod-mode }},
            "ktpDomains": $(jq -Rcs '[. | split("\n") | .[] | match("host-record=(.+),.+").captures[0].string]' "$PATH_DNSMASQ_STATIC_DNS_CONF"),
            "dnsmasqConfigOutputFile": "$PATH_DNSMASQ_KTP_ALIASES_CONF",
            "ports": {"discovery": $DISCOVERY_PORT}
        }
    }
    EOF
    )
    
    if [[ "{{ only-to-console }}" == "true" ]]; then
        export CONSOLE_ONLY_OUTPUT=true
    fi

    deno run dev "$CONFIG"

start-prod:
    just start true

start-oneshot:
    just start false true

test flags="":
    LOG_LEVEL=silent deno run tests -- {{ flags }}

generate-dev-conf:
    rm -rf devconf
    mkdir -p devconf

    # Generate fake DNS records file that mimics that generated by ytl-linux-digabi2-examnet
    for i in $(seq 1 24); do echo "host-record=ktp$i.1000.koe.abitti.net,192.168.$((i * 10)).1" >> devconf/ytl-linux-static-dns-records.conf; done
