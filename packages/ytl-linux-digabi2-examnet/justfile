[private]
mod mod-bouncer 'lib/bouncer.just'
[private]
mod mod-destroy 'lib/destroy.just'
[private]
mod mod-discovery 'lib/discovery.just'
[private]
mod network 'lib/network.just'
[private]
mod mod-restart-bouncer 'lib/restart-bouncer.just'
[private]
mod setup 'lib/setup.just'
[private]
mod util 'lib/util.just'

[private]
default:
    @just --list --unsorted

bouncer net-device-wan net-device-lan server-number: util::assert-user-is-root
    just mod-bouncer bouncer {{net-device-wan}} {{net-device-lan}} {{server-number}}

restart-bouncer net-device-wan net-device-lan server-number: util::assert-user-is-root
    just mod-restart-bouncer restart-bouncer {{net-device-wan}} {{net-device-lan}} {{server-number}}

discovery net-device-wan net-device-lan server-number: util::assert-user-is-root
    just mod-discovery discovery {{net-device-wan}} {{net-device-lan}} {{server-number}}

configure net-device-wan net-device-lan server-number optional-server-name="": util::assert-user-is-root
    #!/usr/bin/env bash
    set -euo pipefail

    if [[ -n "{{optional-server-name}}" ]]; then
      SERVER_NAME="{{optional-server-name}}"
    else
      SERVER_NAME=$(just setup get-server-friendly-name "$PATH_NAKSU2_DOMAIN" $EXIT_CODE_INVALID_SERVER_NAME)
    fi
    echo "DEBUG: Using server friendly name '$SERVER_NAME'"
    just setup apply {{net-device-wan}} {{net-device-lan}} {{server-number}} "$SERVER_NAME"

destroy  net-device-wan net-device-lan server-number: util::assert-user-is-root
    just mod-destroy destroy {{net-device-wan}} {{net-device-lan}} {{server-number}}