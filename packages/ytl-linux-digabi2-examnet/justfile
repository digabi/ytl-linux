[private]
mod mod-bouncer 'lib/bouncer.just'
[private]
mod mod-discovery 'lib/discovery.just'
[private]
mod etc-hosts 'lib/etc-hosts.just'
[private]
mod fs 'lib/fs.just'
[private]
mod log 'lib/log.just'
[private]
mod network 'lib/network.just'
[private]
mod setup 'lib/setup.just'
[private]
mod systemd 'lib/systemd.just'
[private]
mod static-dns-records 'lib/static-dns-records.just'
[private]
mod util 'lib/util.just'

[private]
default:
    @just --list --unsorted

configure net-device-wan net-device-lan server-number server-friendly-name="": util::assert-user-is-root
    #!/usr/bin/env bash
    set -euo pipefail

    if [[ -n "{{server-friendly-name}}" ]]; then
      SERVER_FRIENDLY_NAME="{{server-friendly-name}}"
    else
      SERVER_FRIENDLY_NAME="ktp{{server-number}}"
    fi

    just setup apply {{net-device-wan}} {{net-device-lan}} {{server-number}} "$SERVER_FRIENDLY_NAME"

destroy: util::assert-user-is-root
    just setup destroy

bouncer: util::assert-user-is-root
    just mod-bouncer start

restart-bouncer: util::assert-user-is-root
    just mod-bouncer restart

discovery: util::assert-user-is-root
    just mod-discovery start
