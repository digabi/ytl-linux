mod setup 'lib/setup.just'

[private]
default:
    @just --list --unsorted

configure net-device-wan net-device-lan server-number server-name: assert-user-is-root
  just setup apply {{net-device-wan}} {{net-device-lan}} {{server-number}} {{server-name}}

[private]
assert-user-is-root:
  #!/usr/bin/env bash
  set -euo pipefail

  if [[ ${TEST_MODE:-} != "test" && $EUID -ne 0 ]]; then
    echo "Error: This script must be run as root"
    exit $EXIT_CODE_MUST_BE_ROOT
  fi
