# Lists all tasks in the order they appear in the justfile
[private]
default:
    @just --list --unsorted

# Format justfiles
[private]
format:
    @just --unstable --fmt

start: generate-dev-conf
    deno run dev \
      --friendly-name-file devconf/server-friendly-name \
      --ncsi-hostnames-file ../conf/ncsi-hostnames \
      --dns-records-file devconf/ytl-linux-static-dns-records.conf \
      --dns-hostname-file devconf/domain.txt \
      --server-own-ip-file devconf/server-own-ip \
      --dns-search-domain internal \
      --tls-key-file devconf/key.pem \
      --tls-cert-file devconf/cert.pem \
      --dnsmasq-config-file devconf/ytl-linux-ktp-aliases.conf

test:
    deno run tests

generate-dev-conf friendly-name="jotain-puppua" skip-cert-if-exists="true":
    #!/usr/bin/env bash
    set -euo pipefail

    rm -rf devconf
    mkdir -p devconf

    KTP_DOMAINS=()

    # Generate fake DNS records file that mimics that generated by ytl-linux-digabi2-examnet
    for i in $(seq 1 24); do
        KTP_DOMAINS+=(ktp$i.1000.koe.abitti.net)
        echo "host-record=ktp$i.1000.koe.abitti.net,192.168.$((i * 10)).1" >> devconf/ytl-linux-static-dns-records.conf
    done

    if [[ "{{ skip-cert-if-exists }}" == "false" || (! -f devconf/cert.pem && ! -f devconf/key.pem) ]]; then
        # Generate fake certificate that mimics the ones generated for schools
        mkcert -cert-file devconf/cert.pem -key-file devconf/key.pem ${KTP_DOMAINS[@]}
    fi

    echo '{{ friendly-name }}' > devconf/server-friendly-name
    echo 'ktp1.1000.koe.abitti.net' > devconf/domain.txt
    echo '192.168.10.1' > devconf/server-own-ip
