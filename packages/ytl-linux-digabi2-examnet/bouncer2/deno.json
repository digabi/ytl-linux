{
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env --allow-sys --watch src/main.ts",
    "tests": "deno test --allow-net --allow-read --allow-env --allow-sys tests/**/*.test.ts",
    "build": "deno compile --allow-net --allow-read --allow-env --allow-sys --output ../deb-root/usr/local/sbin/bouncer2 --target x86_64-unknown-linux-gnu src/main.ts"
  },
  "imports": {
    "@gabriel/ts-pattern": "jsr:@gabriel/ts-pattern@^5.9.0",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@types/lodash": "npm:@types/lodash@^4.17.24",
    "@zod/zod": "jsr:@zod/zod@^4.3.6",
    "lodash": "npm:lodash@^4.17.23",
    "pino": "npm:pino@^10.3.1",
    "pino-pretty": "npm:pino-pretty@^13.1.3"
  }
}
