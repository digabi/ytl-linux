#!/usr/bin/env bash
set -euo pipefail

readonly PATH_EXAMNET_CONFIG=/etc/ytl-linux-digabi2-examnet/config
readonly PATH_SERVER_OWN_IP="$PATH_EXAMNET_CONFIG/server-own-ip"
readonly PATH_NET_DEVICE_LAN_CONF="$PATH_EXAMNET_CONFIG/net-device-lan"

if [ ! -f "$PATH_SERVER_OWN_IP" ] || [ ! -f "$PATH_NET_DEVICE_LAN_CONF" ]; then
    echo "examnet not configured, skipping wait"
    exit 0
fi

readonly SERVER_OWN_IP="$(cat "$PATH_SERVER_OWN_IP")"
readonly NET_DEVICE_LAN="$(cat "$PATH_NET_DEVICE_LAN_CONF")"

echo "Waiting for $SERVER_OWN_IP on $NET_DEVICE_LAN..."
for _ in $(seq 1 30); do
    if ip -4 addr show dev "$NET_DEVICE_LAN" 2>/dev/null | grep -q "inet ${SERVER_OWN_IP}/"; then
        echo "OK: $SERVER_OWN_IP plumbed on $NET_DEVICE_LAN"
        exit 0
    fi
    sleep 1
done

echo "Timeout: $SERVER_OWN_IP not plumbed on $NET_DEVICE_LAN after 30s" >&2
exit 1
