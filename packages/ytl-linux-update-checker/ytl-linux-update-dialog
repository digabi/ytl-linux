#!/usr/bin/env python3

# pylint: disable=missing-module-docstring,missing-class-docstring,missing-function-docstring, invalid-name

import sys
import subprocess
import datetime as dt
from pathlib import Path
import gi
from systemd import journal  # pylint: disable=import-error # pyright: ignore[reportMissingImports]

# N.B.: this line _has_ to be executed before `from gi.repository import Gtk`
gi.require_version('Gtk', '3.0')

from gi.repository import GLib  # pylint: disable=wrong-import-position # pyright: ignore[reportAttributeAccessIssue]
from gi.repository import Gtk  # pylint: disable=wrong-import-position # pyright: ignore[reportAttributeAccessIssue]

CONFIG_PATH = Path("/var/lib/ytl-linux-update-check")
SNOOZE_FILE_PATH = Path(CONFIG_PATH, "snoozed-until")
SNOOZE_TIME = dt.timedelta(hours=24)
SYSLOG_IDENTIFIER = "ytl-linux-software-update"
LOGLEVEL_INFO = 6
LOGLEVEL_WARN = 4
LOGLEVEL_ERR = 3
LOGLEVEL_DEBUG = 7


def log(msg: str, level=LOGLEVEL_INFO):
    journal.send(msg, SYSLOG_IDENTIFIER=SYSLOG_IDENTIFIER, PRIORITY=level)


def snooze():
    try:
        CONFIG_PATH.mkdir(parents=True, exist_ok=True)
    except PermissionError as e:
        log(f"ERR: {e}", LOGLEVEL_ERR)

    now = dt.datetime.now(dt.timezone.utc)
    snooze_until = now + SNOOZE_TIME

    log(f"Snoozing update notification until {snooze_until.astimezone()}")

    try:
        with SNOOZE_FILE_PATH.open("w", encoding="UTF-8") as snooze_file:
            snooze_file.write(str(snooze_until.timestamp()))
    except FileNotFoundError as e:
        log(f"ERR: {e}", LOGLEVEL_ERR)


def is_snoozed():
    log("Checking if update notification is snoozed")

    if SNOOZE_FILE_PATH.exists():
        with SNOOZE_FILE_PATH.open("r", encoding="UTF-8") as snooze_file:
            now = dt.datetime.now(dt.timezone.utc)
            snooze_until = dt.datetime.fromtimestamp(
                float(snooze_file.read()), tz=dt.timezone.utc)
            snooze_not_expired = now < snooze_until
            log(f"Update notification is {'' if snooze_not_expired else 'not '}" +
                f"snoozed (now={now.astimezone()}, snooze_until={snooze_until.astimezone()})")
            return snooze_not_expired

    log("Update notification has not been snoozed")
    return False


class UpdateDialog(Gtk.Window):
    def __init__(self):
        super().__init__(title="YTL Linux Software Update")
        self.set_border_width(10)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_default_size(400, 200)
        self.selected_lang = "fi"
        self.will_update = False
        self.proc: subprocess.Popen[bytes] | None = None

        self.available_updates = "\n".join(
            update.strip() for update in "".join(sys.argv[1:]).split(";"))

        translations = i18n(self.available_updates)

        self.label_text = translations.label_text

        self.progress_bar_text = translations.progress_bar_text

        self.success_text = translations.success_text

        self.error_text = translations.error_text

        self.button_snooze_text = translations.button_snooze_text

        self.button_commit_text = translations.button_commit_text

        box_main = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        self.add(box_main)

        # Language selection box

        box_language_selection = Gtk.Box(
            orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        box_main.pack_start(box_language_selection, True, True, 0)

        button_fi = Gtk.Button(label="suomeksi")
        button_fi.connect("clicked", self.on_language_change, "fi")
        box_language_selection.pack_start(button_fi, True, True, 0)

        button_sv = Gtk.Button(label="på svenska")
        button_sv.connect("clicked", self.on_language_change, "sv")
        box_language_selection.pack_start(button_sv, True, True, 0)

        button_en = Gtk.Button(label="in English")
        button_en.connect("clicked", self.on_language_change, "en")
        box_language_selection.pack_start(button_en, True, True, 0)

        # Label box

        box_label = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        box_main.pack_start(box_label, True, True, 0)

        self.stack = Gtk.Stack()

        self.label = Gtk.Label()
        self.stack.add_named(self.label, "label")

        self.progress_bar = Gtk.ProgressBar()
        self.stack.add_named(self.progress_bar, "progress_bar")

        self.stack.set_visible_child_name("label")
        box_label.pack_start(self.stack, True, True, 0)

        # Action box

        box_action = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        box_main.pack_start(box_action, True, True, 0)

        self.button_snooze = Gtk.Button()
        self.button_snooze.connect("clicked", self.on_snooze)
        box_action.pack_start(self.button_snooze, True, True, 0)

        self.button_commit = Gtk.Button()
        self.button_commit.connect("clicked", self.on_commit)
        box_action.pack_start(self.button_commit, True, True, 0)

        self.on_language_change(None, "fi")

        # Closing the window should snooze too
        self.connect("destroy", self.on_snooze)

    def on_language_change(self, _, lang: str):
        self.selected_lang = lang
        self.label.set_markup(self.label_text[self.selected_lang])
        self.button_snooze.set_label(
            self.button_snooze_text[self.selected_lang])
        self.button_commit.set_label(
            self.button_commit_text[self.selected_lang])
        self.progress_bar.set_text(self.progress_bar_text[self.selected_lang])

    def on_commit(self, _):
        self.button_commit.set_sensitive(False)
        self.button_snooze.set_sensitive(False)

        self.progress_bar.set_show_text(True)
        self.progress_bar.set_text(self.progress_bar_text[self.selected_lang])
        self.progress_bar.set_fraction(0.0)
        self.stack.set_visible_child_name("progress_bar")
        self.progress_bar.pulse()
        try:
            self.proc = subprocess.Popen(  # pylint: disable=consider-using-with
                ["/usr/bin/pkexec", "/usr/local/sbin/ytl-linux-software-update"])
        except OSError as e:
            log(f"ERR: {e}", LOGLEVEL_ERR)
            self.progress_bar.set_text("Update failed")
            self.button_commit.set_sensitive(True)
            self.button_snooze.set_sensitive(True)
            return

        GLib.timeout_add(100, self.check_updater)

    def check_updater(self):
        assert self.proc is not None

        if self.proc.poll() is None:
            self.progress_bar.pulse()
            return True      # keep timer running

        returncode = self.proc.wait()
        self.proc = None

        # updater has exited
        if returncode == 0:
            self.progress_bar.set_fraction(1.0)
            self.progress_bar.set_text("Update complete")
            popup = Gtk.MessageDialog(
                transient_for=self,
                modal=True,
                message_type=Gtk.MessageType.INFO,
                buttons=Gtk.ButtonsType.OK,
                text="Update complete"
            )
            popup.format_secondary_text(self.success_text[self.selected_lang])
            popup.run()
            popup.destroy()
            Gtk.main_quit()
        else:
            self.progress_bar.set_text("Update failed")
            popup = Gtk.MessageDialog(
                transient_for=self,
                modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text="Update failed"
            )
            popup.format_secondary_text(self.error_text[self.selected_lang])
            popup.run()
            popup.destroy()
            self.stack.set_visible_child_name("label")
            self.button_commit.set_sensitive(True)
            self.button_snooze.set_sensitive(True)

        return False         # stop timer

    def on_snooze(self, _):
        snooze()
        Gtk.main_quit()


