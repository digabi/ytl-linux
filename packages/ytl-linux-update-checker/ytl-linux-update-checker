#!/usr/bin/env bash

set -euo pipefail

export DISPLAY=':0'

JOURNAL_IDENTIFIER="ytl-linux-software-update"

log() {
  if [[ $# -gt 0 ]]; then
    printf '%s\n' "$*"
  else
    cat
  fi | systemd-cat --identifier "${JOURNAL_IDENTIFIER}"
}

log "Checking for updates in YTL Linux repo"

APT_FLAGS_CHECK_YTL_LINUX_ONLY=(-o Dir::Etc::sourcelist="sources.list.d/ytl-linux.sources" -o Dir::Etc::sourceparts="-" -o APT::Get::List-Cleanup="0")

apt-get update "${APT_FLAGS_CHECK_YTL_LINUX_ONLY[@]}" | log

UPGRADE_DRY_RUN_RESULT="$(apt-get upgrade --dry-run "${APT_FLAGS_CHECK_YTL_LINUX_ONLY[@]}")"
log "${UPGRADE_DRY_RUN_RESULT}"

if echo "${UPGRADE_DRY_RUN_RESULT}" | grep -q "The following packages will be upgraded"; then
  AVAILABLE_UPDATES=$(echo "${UPGRADE_DRY_RUN_RESULT}" | grep Inst)
  UPDATES=()

  # Read each line
  while read -r upgrade; do
    PACKAGE=$(echo "${upgrade}" | cut -d ' ' -f2)
    CURRENT_VERSION=$(echo "${upgrade}" | cut -d ' ' -f3 | sed 's/[][]//g')
    NEW_VERSION=$(echo "${upgrade}" | cut -d ' ' -f4 | sed 's/[()]//g')
    UPDATE_DESCRIPTION="${PACKAGE}: ${CURRENT_VERSION} => ${NEW_VERSION};"
    UPDATES+=("${UPDATE_DESCRIPTION}")
  done <<< "${AVAILABLE_UPDATES}"

  log "The following updates are available: ${UPDATES[*]}"
  
  # FIXME: This is not displaying the updates with newlines and mangles them into one line
  su school -c "/usr/local/bin/ytl-linux-update-dialog \"${UPDATES[*]}\"" | systemd-cat --identifier $JOURNAL_IDENTIFIER
else
  log "No updates available"
fi
