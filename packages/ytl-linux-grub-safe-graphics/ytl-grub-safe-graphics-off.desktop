[Desktop Entry]
Version=1.0
Name=Display: Normal Graphics On Boot
Comment=Removes "nomodeset" kernel parameter for normal graphics mode
Exec=pkexec /usr/local/sbin/ytl-grub-safe-graphics off
Terminal=false
Type=Application
Categories=Settings;DesktopSettings;
Icon=/usr/local/share/pixmaps/ytl-grub-safe-graphics.png
