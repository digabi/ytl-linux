#!/usr/bin/env bash

set -euo pipefail

ZENITY_WIDTH=300
GRUB_CONF=/etc/default/grub

if [[ -z "${1:-}" || ! "${1}" =~ ^(on|off)$ ]]; then
  echo "Usage: $0 <on|off>"
  exit 1
fi

MODE="$1"

if ! TEMPFILE=$(mktemp --suffix ytl-grub-safe-graphics); then
  zenity --error --width=${ZENITY_WIDTH} --text="Failed to create temporary file"
  exit 1
fi

if [[ "$MODE" == "on" ]]; then
  if ! cat $GRUB_CONF | perl -e 'while (<STDIN>) { if (/GRUB_CMDLINE_LINUX_DEFAULT/ && ! /nomodeset/) { s/\"/\"nomodeset /; s/(\s)+/$1/g; } print $_; }' > "$TEMPFILE"; then
    zenity --error --width=${ZENITY_WIDTH} --text="Failed to add 'nomodeset' entry to grub configuration"
    exit 1
  fi
else
  if ! cat $GRUB_CONF | perl -e 'while (<STDIN>) { if (/GRUB_CMDLINE_LINUX_DEFAULT/) { s/nomodeset//gi; s/(\s)+/$1/g; } print $_; }' > "$TEMPFILE"; then
    zenity --error --width=${ZENITY_WIDTH} --text="Failed to remove 'nomodeset' entry from grub configuration"
    exit 1
  fi
fi

if ! mv "$TEMPFILE" "$GRUB_CONF"; then
  zenity --error --width=${ZENITY_WIDTH} --text="Failed to replace grub configuration with ${TEMPFILE}"
  exit 1
fi

if ! update-grub 2>&1 | zenity --progress --pulsate --text="Please wait..." --auto-close --no-cancel; then
  zenity --error --width=${ZENITY_WIDTH} --text="Failed to re-create grub configuration (update-grub)"
  exit 1
fi

zenity --info --width=${ZENITY_WIDTH} --text="Safe Graphics setting has been set to ${GRUB_CONF}"
