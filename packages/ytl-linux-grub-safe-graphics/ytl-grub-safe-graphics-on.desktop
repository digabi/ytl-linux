[Desktop Entry]
Version=1.0
Name=Display: Safe Graphics On Boot
Comment=Adds "nomodeset" kernel parameter for safe graphics mode
Exec=pkexec /usr/local/sbin/ytl-grub-safe-graphics on
Terminal=false
Type=Application
Categories=Settings;DesktopSettings;
Icon=/usr/local/share/pixmaps/ytl-grub-safe-graphics.png
